# PostgreSQL Database Connection URL (Same as user-facing P2P site)
DATABASE_URL="postgresql://user:password@hostname:port/database?sslmode=require"

# Admin Access Credentials (Master)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="p2pexchangeadmin"

# JWT Secret for Session cookies
ADMIN_JWT_SECRET="generate-a-secure-random-jwt-token-secret-key-32-chars"
